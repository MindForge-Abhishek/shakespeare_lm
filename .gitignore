
#.   macOS

.DS_store 
# This will be ignored because this is created by mac to save finder settings 
# which is completely irrelevant to our project 
# not putting this will pollute out git history 


#  Python files

__pycache__/

# This are  created automatically by python when it runs .py code files
# Inside these python store precompiled version of code for speedupd just like cache of internet
# They are auto generated on each run  so tracking them is pointless as they change constantly

*.py[cod]

# These are three type of files generated by python interpreter at every run of py files
# First file is .pyc of cod which stores the coplied python bytecode level code of the original source code 
# Second is .pyo it stored optimized compiled bytecode in newer version of python it have replaced by .pyc
# third is .pyd is  just a python extention module for windows nothing have to do with my machine mean Mac


#  Jupyter 

.ipynb_checkpoints

# Jupyter automatically creates a hidden folder called .ipynb_checkpoints every time you open a notebook
# It saves autosave backups of your notebook inside
# These are NOT a real notebook files
# They change every few minutes automatically
# Tracking them creates noisy, meaningless Git history

# ==================================================
# Machine Learning
# ==================================================

# Our model saves its state here during training
# These files are called checkpoints
# They can be GIGABYTES in size for large models
# Git is not designed for large binary files
# Checkpoints should be stored separately
# (cloud storage, Google Drive, etc.)
# We recreate them by running training again
checkpoints/

# Training produces log files here
# Logs record loss values, metrics, timestamps
# They are outputs of training runs, not source code
# Different every run — not meaningful to track in Git
logs/

# Our raw downloaded data lives here
# Shakespeare.txt is small (~1MB) but we ignore it anyway
# Real datasets are gigabytes or terabytes
# Data should be downloaded via our download script
# not stored inside Git
# This builds the correct professional habit
data/raw/

# Preprocessed data saved as tensors lives here
# These files are generated by our preprocessing script
# They can be recreated anytime from raw data
# They can be of very big in size so we should not track it through git this should be done by external party
# No need to track auto-generated files in Git
data/processed/

# ==================================================
# Environment
# ==================================================

# .env files store SECRET information
# API keys, passwords, database credentials
# If this ever reaches GitHub, automated bots
# scan and find secrets within MINUTES
# This line is non-negotiable — always ignore .env
.env

# These are virtual environment FOLDERS
# Sometimes people create Python environments
# inside their project folder named env/ or venv/
# These folders contain thousands of files
# and are hundreds of megabytes in size
# They are machine-specific — never share via Git
# We use environment.yml to recreate environments instead
env/
venv/




